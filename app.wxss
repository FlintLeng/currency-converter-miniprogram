/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

/* 主卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 货币选择行 */
.currency-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.currency-row:last-child {
  border-bottom: none;
}

.currency-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.currency-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.currency-name {
  font-size: 28rpx;
  color: #333333;
}

.currency-code {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 金额输入 */
.amount-input {
  text-align: right;
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
  min-width: 200rpx;
}

.amount-input placeholder {
  color: #cccccc;
}

/* 汇率信息 */
.rate-info {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999999;
}

/* 转换按钮 */
.convert-btn {
  background: linear-gradient(135deg, #1E88E5, #1565C0);
  color: #ffffff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 30rpx;
  border: none;
}

.convert-btn::after {
  border: none;
}

/* 交换按钮 */
.swap-btn {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.swap-icon {
  width: 60rpx;
  height: 60rpx;
  background-color: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 结果显示 */
.result-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-top: 20rpx;
  text-align: center;
}

.result-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.result-amount {
  font-size: 56rpx;
  font-weight: bold;
  color: #1E88E5;
}

.result-currency {
  font-size: 28rpx;
  color: #666666;
  margin-top: 10rpx;
}

/* 货币列表 */
.currency-list {
  margin-top: 30rpx;
}

.currency-list-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.currency-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.currency-item-left {
  display: flex;
  align-items: center;
}

.currency-item-rate {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 更新时间 */
.update-time {
  text-align: center;
  font-size: 22rpx;
  color: #cccccc;
  margin-top: 30rpx;
  padding-bottom: 30rpx;
}

/* 货币图标颜色 */
.icon-cny { background: linear-gradient(135deg, #E53935, #C62828); }
.icon-usd { background: linear-gradient(135deg, #1E88E5, #1565C0); }
.icon-hkd { background: linear-gradient(135deg, #43A047, #2E7D32); }
.icon-eur { background: linear-gradient(135deg, #5E35B1, #4527A0); }
.icon-jpy { background: linear-gradient(135deg, #F4511E, #D84315); }
.icon-sgd { background: linear-gradient(135deg, #00ACC1, #00838F); }
.icon-krw { background: linear-gradient(135deg, #FFA726, #FB8C00); }
